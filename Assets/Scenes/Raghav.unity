      m_Calls: []
  m_text: "Baby of Raghav             Age:2 Years,Male                  MRD.No: NICU
    0023/23\r\n\r\n\rBIO CHEMISTRY                                                                              
    \r\n                                                                            
    Normal Range\r\n\r\nSODIUM               132  mEq/L                               
    135-145 mEq/L\r\n\nPOTASSIUM          5.8  mEq/L                               
    3.5-5.3  mEq/L\r\n\nCHLORIDE            102 mEq/L                                
    98-108 mEq/L\r\n\r\nBICARBONATE      18  mEq/L                                
    22-28 mEq/L\r\n\nUREA(BUN)            48 mg/dl                                   
    5-18 mg/dl\r\n\r\nCREATININE          2.4 mg/dl                                   
    0.4-0.7 mg/dl\r\n\r\nGLUCOSE              70 mg/dl                                   
    60- 100 mg/dl   \r\n\r\nCRP                        0.8 mg/dl                           
    Less than 1 mg/dl\r\n\nWBC COUNT           9000 mm\xB3                            
    4000-11000mm\xB3 \r\n\nHAEMOGLOBIN          12 Gm%                               
    12-14 g%\n\r\nPLATELETS              200000mm\xB3               150000- 300000/c.mm\xB3\n\n\n"
